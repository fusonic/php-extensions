{
    "name": "fusonic/mailer-extensions",
    "license": "MIT",
    "version": "1.0.5",
    "description": "Symfony Mailer Component Extensions.",
    "type": "library",
    "authors": [
        {
            "name": "Fusonic GmbH",
            "email": "office@fusonic.net"
        }
    ],
    "autoload": {
        "psr-4": {
            "Fusonic\\MailerExtensions\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Fusonic\\MailerExtensions\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.3",
        "phpstan/phpstan": "^0.12.42",
        "friendsofphp/php-cs-fixer": "^2.16.1"
    },
    "require": {
        "php": ">=7.4",
        "symfony/mime": "^4.4.4 || ^5.1",
        "symfony/mailer": "^4.4.4 || ^5.1",
        "symfony/messenger": "^4.4.4 || ^5.1"
    },
    "scripts": {
        "phpstan": "vendor/bin/phpstan analyse",
        "phpcs-check": "vendor/bin/php-cs-fixer fix --config=.php_cs.dist -v --dry-run --diff --using-cache=yes",
        "phpcs-fix": "vendor/bin/php-cs-fixer fix --config=.php_cs.dist -v --using-cache=yes"
    }
}
